# Google Search API
GOOGLE_CSE_KEY="your_api_key_here"
GOOGLE_CSE_ID="your_cse_id_here"

# Redis Configuration (for caching)
# Use 'localhost' if running directly on host, or container name if in docker network
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_CONTAINER="wiki_stream-redis-1" # Only used if using docker exec fallback

# Reddit User Agent (Optional - Prevent 429s)
REDDIT_USER_AGENT="SearchClusterBot/1.0 (by /u/yourname)"
