# Search Cluster Config
GOOGLE_CSE_KEY=your-api-key
GOOGLE_CSE_ID=your-engine-id
# Optional: Use GOOGLE_API_KEY if CSE_KEY is not set
# GOOGLE_API_KEY=your-google-api-key

# Redis Configuration
# Option 1: Direct Connection (Recommended)
REDIS_HOST=localhost
REDIS_PORT=6379
# Option 2: Docker Container (Legacy Fallback)
REDIS_CONTAINER=wiki_stream-redis-1

# Reddit Configuration (Optional)
REDDIT_USER_AGENT=SearchClusterBot/1.0
